# Visitor analytics (optional)
# Pick ONE provider below. Leave blank to disable tracking.

# Plausible — privacy-friendly, recommended (https://plausible.io)
# After signup, add your domain and paste it here:
PUBLIC_PLAUSIBLE_DOMAIN=

# Umami — self-hosted or cloud (https://umami.is)
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js

# Base path for deployment
# GitHub Pages project site: /repo-name (default)
# Vercel/custom domain: set to /
PUBLIC_BASE_PATH=/atharv-portfolio
